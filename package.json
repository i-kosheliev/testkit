{
  "name": "@iklab/testkit",
  "version": "1.1.0",
  "description": "Test quality toolkit — boundary values, flakiness prediction, duplicate detection, static test scanner.",
  "author": "Ihor Kosheliev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/i-kosheliev/testkit.git"
  },
  "keywords": [
    "testing",
    "test-data",
    "boundary-values",
    "edge-cases",
    "flakiness",
    "jest",
    "vitest",
    "playwright",
    "test-each",
    "ISTQB",
    "duplicate-detection",
    "test-automation",
    "static-analysis",
    "cli",
    "scanner"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "bin": {
    "testkit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/i-kosheliev/testkit#readme",
  "bugs": {
    "url": "https://github.com/i-kosheliev/testkit/issues"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@sveltejs/acorn-typescript": "^1.0.9",
    "acorn": "^8.16.0"
  }
}
